// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  studentId String    @unique
  password  String
  role      Role      @default(STUDENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  student   Student?
  courseRep CourseRep?
}

enum Role {
  STUDENT
  COURSE_REP
}

model ClassSpace {
  id           Int       @id @default(autoincrement())
  name         String
  department   String
  level        Int
  academicYear String
  classCode    String    @unique
  createdAt    DateTime  @default(now())

  courseRep    CourseRep  @relation(fields: [courseRepId], references: [id])
  courseRepId  Int        @unique

  students     Student[]
  courses      Course[]
  sessions     Session[]
}

model CourseRep {
  id         Int        @id @default(autoincrement())
  department String
  level      Int

  user       User       @relation(fields: [userId], references: [id])
  userId     Int        @unique

  classSpace ClassSpace?

  // A course rep is also a student - just reference the student directly
  studentId  Int?       @unique
  student    Student?   @relation(fields: [studentId], references: [id])
}

model Student {
  id           Int         @id @default(autoincrement())
  department   String?
  level        Int?

  user         User        @relation(fields: [userId], references: [id])
  userId       Int         @unique

  classSpace   ClassSpace? @relation(fields: [classSpaceId], references: [id])
  classSpaceId Int?

  // A student can optionally be a course rep (referenced by CourseRep)
  courseRep    CourseRep?

  attendance   Attendance[]
}

model Course {
  id           Int        @id @default(autoincrement())
  code         String
  name         String
  lecturerName String?
  createdAt    DateTime   @default(now())

  classSpace   ClassSpace @relation(fields: [classSpaceId], references: [id])
  classSpaceId Int

  sessions     Session[]

  @@unique([code, classSpaceId])
}

model Session {
  id           Int       @id @default(autoincrement())
  date         DateTime  @default(now())
  startTime    DateTime  @default(now())
  endTime      DateTime?
  latitude     Float
  longitude    Float
  radiusMeters Int       @default(100)
  isOpen       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  course       Course    @relation(fields: [courseId], references: [id])
  courseId     Int

  classSpace   ClassSpace @relation(fields: [classSpaceId], references: [id])
  classSpaceId Int

  attendance   Attendance[]
}

model Attendance {
  id        Int              @id @default(autoincrement())
  status    AttendanceStatus @default(ABSENT)
  latitude  Float?
  longitude Float?
  markedAt  DateTime         @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
  studentId Int

  session   Session  @relation(fields: [sessionId], references: [id])
  sessionId Int

  @@unique([studentId, sessionId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}